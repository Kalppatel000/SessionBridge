{
  "manifest_version": 3,
  "name": "SessionBridge",
  "version": "1.0.0",
  "description": "Share browser sessions with MCP servers — zero API keys",
  "permissions": ["storage", "activeTab", "nativeMessaging", "cookies"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
