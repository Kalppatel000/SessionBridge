{
  "manifest_version": 3,
  "name": "SessionBridge",
  "version": "1.0.1",
  "description": "Share browser sessions with MCP servers — zero API keys",
  "permissions": ["storage", "nativeMessaging", "cookies"],
  "host_permissions": [
    "https://*.service-now.com/*",
    "https://*.atlassian.net/*",
    "https://*.salesforce.com/*",
    "https://github.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.service-now.com/*",
        "https://*.atlassian.net/*",
        "https://*.salesforce.com/*",
        "https://github.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "optional_host_permissions": ["<all_urls>"]
}
